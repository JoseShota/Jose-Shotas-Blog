---
import BaseLayout from '../layouts/Layout.astro';
import BitacoraVirtual from '../components/BitacoraVirtual.jsx';

const pageTitle = "Bitacora Virtual // Notas Mentales";
---

<BaseLayout title={pageTitle}>
  <h2 style="var(--color-highlight); margin-top: 0;">> BITACORA / MEMORIA_ACTIVA</h2>

  <p style="font-size: 0.9rem; font-style: italic; opacity: 0.8; margin-bottom: 2rem;">
    Publica notas mentales en modo editor y previsualiza su version publica retro con el boton de vista.
  </p>

  <div style="border-top: 1px dashed #333; padding-top: 2rem;">
    <BitacoraVirtual client:load />
  </div>
</BaseLayout>